{
  "name": "youtube-learning-ios",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm --prefix src/y2026/youtube_agent_2/frontend run dev",
    "build": "npm --prefix src/y2026/youtube_agent_2/frontend run build:mobile",
    "preview": "npm --prefix src/y2026/youtube_agent_2/frontend run preview",
    "frontend:install": "npm --prefix src/y2026/youtube_agent_2/frontend ci",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "ios:run": "npm run build && cap run ios"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^7.3.1",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.2",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/keyboard": "^7.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "typescript": "^5.9.3"
  }
}

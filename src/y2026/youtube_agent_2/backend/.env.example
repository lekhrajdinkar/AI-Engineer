# Firebase Admin service account JSON as a single-line JSON value.
FIREBASE_ENABLED=true
FIREBASE_AUTH_REQUIRED=true
FIREBASE_PROJECT_ID=agent-2026-d3f51
FIREBASE_SERVICE_ACCOUNT_JSON=
# Preferred locally: absolute path to the downloaded Firebase Admin key file.
GOOGLE_APPLICATION_CREDENTIALS=
FRONTEND_URL=http://localhost:5173

# Microservice configuration. Use the same long random token in the plans and
# YouTube services. The gateway does not send this credential.
INTERNAL_SERVICE_TOKEN=
YOUTUBE_SERVICE_URL=http://localhost:8002
GATEWAY_YOUTUBE_SERVICE_URL=http://localhost:8002
GATEWAY_PLANS_SERVICE_URL=http://localhost:8003
SERVICE_REQUEST_TIMEOUT_SECS=30

# Optional service-owned SQLite paths. Production should keep Firestore enabled.
YOUTUBE_DATABASE_PATH=
PLANS_DATABASE_PATH=

# AI course generation (Groq has a hosted free plan suitable for this POC).
GROQ_API_KEY=
AI_LLM_MODEL=openai/gpt-oss-20b
AI_LLM_TEMPERATURE=0
AI_LLM_TIMEOUT_SECS=60
AI_LLM_MAX_RETRIES=2
AI_MAX_VIDEOS_PER_REQUEST=50
AI_VIDEO_DESCRIPTION_MAX_CHARS=240

# Google OAuth Web Client values. Create a local callback URI in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/auth/google/callback

# Generate independent secret values. Do not commit the populated .env file.
YOUTUBE_TOKEN_ENCRYPTION_KEY=
# python -c "import secrets; print(secrets.token_urlsafe(32))"
YOUTUBE_OAUTH_STATE_SECRET=
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

# Firebase Admin service account JSON as a single-line JSON value.
FIREBASE_ENABLED=true
FIREBASE_AUTH_REQUIRED=true
FIREBASE_PROJECT_ID=agent-2026-d3f51
FIREBASE_SERVICE_ACCOUNT_JSON=
# Preferred locally: absolute path to the downloaded Firebase Admin key file.
GOOGLE_APPLICATION_CREDENTIALS=
FRONTEND_URL=http://localhost:5173

# Google OAuth Web Client values. Create a local callback URI in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/auth/google/callback

# Generate independent secret values. Do not commit the populated .env file.
YOUTUBE_TOKEN_ENCRYPTION_KEY=
# python -c "import secrets; print(secrets.token_urlsafe(32))"
YOUTUBE_OAUTH_STATE_SECRET=
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
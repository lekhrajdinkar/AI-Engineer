{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "YouTube Video Metadata Schema",
  "description": "Structured schema for indexed YouTube technical content",
  "type": "object",
  "required": ["id", "title", "author", "video_url", "published_date", "tags"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (URL hash or UUID)",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "description": "Exact video title",
      "maxLength": 200
    },
    "author": {
      "type": "string",
      "description": "Channel name or creator",
      "maxLength": 100
    },
    "channel_url": {
      "type": "string",
      "format": "uri",
      "description": "Link to creator's YouTube channel"
    },
    "video_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://www\\.youtube\\.com/watch\\?v=",
      "description": "Direct YouTube video link"
    },
    "published_date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 format (YYYY-MM-DD)"
    },
    "duration_minutes": {
      "type": ["integer", "null"],
      "description": "Video length in minutes, null if unknown",
      "minimum": 0,
      "maximum": 600
    },
    "description": {
      "type": "string",
      "description": "Full description or 200-word summary"
    },
    "tags": {
      "type": "object",
      "required": ["primary_category", "subcategories", "topics"],
      "properties": {
        "primary_category": {
          "type": "string",
          "enum": [
            "01_PROGRAMMING_LANGUAGE",
            "02_SYSTEM_DESIGN",
            "03_CLOUD_COMPUTING",
            "04_DOCKER_KUBERNETES",
            "05_CI_CD_PIPELINE",
            "06_IAC_TERRAFORM",
            "07_MESSAGE_BROKER",
            "08_DATABASES",
            "21_SOFTWARE_ARCHITECTURE",
            "22_DATA_ENGINEERING",
            "23_AI_ML_ENGINEERING",
            "99_OTHERS"
          ]
        },
        "subcategories": {
          "type": "array",
          "description": "Specific topics within the primary category",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "topics": {
          "type": "array",
          "description": "Technical concepts and keywords covered",
          "items": {
            "type": "string"
          }
        },
        "difficulty": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"],
          "description": "Target audience expertise level"
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "ISO 639-1 language code (e.g., 'en', 'de', 'fr')"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relevance to technical content (0.0-1.0)"
        },
        "view_count": {
          "type": ["integer", "null"],
          "description": "YouTube view count, null if unavailable"
        },
        "like_count": {
          "type": ["integer", "null"],
          "description": "Approximate like count"
        },
        "comment_count": {
          "type": ["integer", "null"],
          "description": "Comment count"
        },
        "series_name": {
          "type": ["string", "null"],
          "description": "Name of video series if applicable"
        },
        "series_index": {
          "type": ["string", "null"],
          "description": "Position in series (e.g., '5 of 10')"
        }
      }
    },
    "indexed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when video was indexed"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last metadata refresh"
    }
  },
  "examples": [
    {
      "id": "dQw4w9WgXcQ",
      "title": "Kubernetes Networking Explained",
      "author": "TechWithLarry",
      "channel_url": "https://www.youtube.com/channel/UCxxxxxxxx",
      "video_url": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
      "published_date": "2024-06-15",
      "duration_minutes": 45,
      "description": "In-depth exploration of Kubernetes networking model, including CNI plugins, service discovery, and network policies.",
      "tags": {
        "primary_category": "04_DOCKER_KUBERNETES",
        "subcategories": ["Kubernetes", "Networking", "Container Orchestration"],
        "topics": ["CNI", "service discovery", "network policies", "ingress", "DNS"],
        "difficulty": "intermediate",
        "language": "en"
      },
      "metadata": {
        "relevance_score": 0.92,
        "view_count": 45230,
        "like_count": 1240,
        "comment_count": 156,
        "series_name": "Kubernetes Deep Dive",
        "series_index": "7 of 12"
      },
      "indexed_at": "2024-07-10T14:30:00Z",
      "last_updated": "2024-07-10T14:30:00Z"
    }
  ]
}

